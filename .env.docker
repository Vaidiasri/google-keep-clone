# Copy to .env.docker and customize before: docker compose --env-file .env.docker up --build

# Shared secrets (must match on both backends)
JWT_SECRET=change-me-in-production
GEMINI_API_KEY=

# Postgres
POSTGRES_USER=todo
POSTGRES_PASSWORD=todo
POSTGRES_DB=todo

# CORS — browser origin(s) allowed to call the APIs
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# Frontend build args (browser reaches APIs via host ports)
VITE_BACKEND_MODE=hybrid
VITE_API_URL_NODE=http://localhost:8080
VITE_API_URL_PYTHON=http://localhost:8000

# FastAPI AI
AI_PROVIDER=gemini
AI_MODEL=gemini-2.0-flash
AI_MAX_REQUESTS_PER_USER_PER_DAY=50
