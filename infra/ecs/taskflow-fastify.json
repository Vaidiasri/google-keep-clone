{
  "family": "taskflow-fastify",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "REPLACE_ECS_EXECUTION_ROLE_ARN",
  "taskRoleArn": "REPLACE_ECS_TASK_ROLE_ARN",
  "containerDefinitions": [
    {
      "name": "fastify",
      "image": "REPLACE_ECR_REGISTRY/taskflow-fastify:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "CORS_ORIGINS",
          "value": "REPLACE_CORS_ORIGINS"
        },
        {
          "name": "AI_MODEL",
          "value": "gemini-2.0-flash"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "REPLACE_SECRET_DATABASE_URL_ARN"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "REPLACE_SECRET_JWT_ARN"
        },
        {
          "name": "GEMINI_API_KEY",
          "valueFrom": "REPLACE_SECRET_GEMINI_ARN"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/taskflow-fastify",
          "awslogs-region": "REPLACE_AWS_REGION",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8080/ping || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 90
      }
    }
  ]
}
