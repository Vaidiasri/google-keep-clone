# JWT / database — JWT_SECRET must match todoBackend for hybrid mode
JWT_SECRET=supersecretkey
DATABASE_URL=postgresql://user:pass@localhost:5432/todo

# Comma-separated browser origins (* = allow all)
# CORS_ORIGINS=http://localhost,https://app.yourdomain.com
# ── AI Stack (pick one provider) ──

# Use Google Gemini (recommended if you have a Gemini API key)
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-from-aistudio-google-com
AI_MODEL=gemini-2.0-flash

# Or use OpenAI instead:
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini

# Rate limit per user per day
AI_MAX_REQUESTS_PER_USER_PER_DAY=50
